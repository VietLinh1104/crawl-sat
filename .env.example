# Thông tin của chính tài khoản bạn được phép sử dụng.
CLASSMARKER_USERNAME=your-email@example.com
CLASSMARKER_PASSWORD=your-password

# Trang dữ liệu cần crawl sau khi đăng nhập. Có thể là trang Results/Tests/Groups.
CLASSMARKER_TARGET_URL=https://www.classmarker.com/a/tests/results/

# Có thể đổi selector nếu giao diện ClassMarker thay đổi.
CLASSMARKER_USERNAME_SELECTOR=input[type="email"], input[name="email"], input[name="username"]
CLASSMARKER_PASSWORD_SELECTOR=input[type="password"]
CLASSMARKER_SUBMIT_SELECTOR=button[type="submit"], input[type="submit"]
CLASSMARKER_TABLE_SELECTOR=table
CLASSMARKER_NEXT_SELECTOR=a[rel="next"], a:has-text("Next"), a:has-text("›")

